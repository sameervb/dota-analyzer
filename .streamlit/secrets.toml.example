# Copy this file to secrets.toml and fill in your values.
# On Streamlit Community Cloud, add these under Settings → Secrets.

# URL of your Ollama instance.
# Local: http://localhost:11434
# Cloudflare Tunnel (recommended for cloud deployment): https://your-tunnel-url.trycloudflare.com
OLLAMA_BASE_URL = "https://your-tunnel-url.trycloudflare.com"

# Ollama model to use for match/draft analysis.
# Recommended: llama3, mistral, phi3
OLLAMA_MODEL = "llama3"
